<Window x:Class="SR1CTRL.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SR1CTRL"
        Width="640"
        Height="720"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.Background}">
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadowEffect"
                          Color="#66000000"
                          BlurRadius="18"
                          Direction="270"
                          ShadowDepth="3"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Effect" Value="{StaticResource CardShadowEffect}"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="118"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Margin="0,0,16,0">
                    <TextBlock Text="SR1CTRL" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource Brush.TextMuted}" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Padding="14,8"
                        CornerRadius="999"
                        BorderThickness="1">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#445877"/>
                    </Border.BorderBrush>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#1E1B273C"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Background" Value="#1E1A3A2A"/>
                                    <Setter Property="BorderBrush" Value="#3A22C55E"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="Background" Value="#1E173246"/>
                                    <Setter Property="BorderBrush" Value="#4433D1FF"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource Brush.TextMuted}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource Brush.Success}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource Brush.Accent}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock FontWeight="Bold" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="OFFLINE"/>
                                    <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Text" Value="CONNECTED"/>
                                            <Setter Property="Foreground" Value="{StaticResource Brush.Success}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Text" Value="RUNNING"/>
                                            <Setter Property="Foreground" Value="{StaticResource Brush.Accent}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="Connection" Style="{StaticResource SectionTitleStyle}"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="COM Port" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                        <ListBox Height="88"
                                 ItemsSource="{Binding PortNames}"
                                 SelectedItem="{Binding SelectedPort}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Baud Rate" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding BaudRate}"/>
                        <Button Margin="0,8,0,0"
                                Content="Refresh Ports"
                                Command="{Binding RefreshPortListCommand}"/>
                    </StackPanel>
                </Grid>
                <WrapPanel>
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Content="Connect"
                            Command="{Binding ConnectCommand}"
                            IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Margin="8,0,0,0"
                            Content="Disconnect"
                            Command="{Binding DisconnectCommand}"
                            IsEnabled="{Binding IsConnected}"/>
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Margin="8,0,0,0"
                            Content="Read D0/D1/D2"
                            IsEnabled="{Binding IsConnected}"
                            Click="ReadDeviceInfoButton_Click"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="Global Motion Control" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Content="Start"
                                Command="{Binding StartCommand}"
                                IsEnabled="{Binding IsConnected}"/>
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Margin="8,0,0,0"
                                Content="Stop"
                                Command="{Binding StopCommand}"
                                IsEnabled="{Binding IsConnected}"/>
                    </StackPanel>
                </DockPanel>
                <TextBlock Text="Linear / Rotate は下のカードで個別に調整できます。"
                           Foreground="{StaticResource Brush.TextMuted}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,4,6">
                <StackPanel>
                    <TextBlock Text="Linear (L0)" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Margin="0,0,8,0"
                                Minimum="{Binding LinearSpeedMin}"
                                Maximum="{Binding LinearSpeedMax}"
                                Value="{Binding L_Speed, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Text="{Binding L_Speed, StringFormat={}{0:F3} /s}"/>
                    </Grid>
                    <TextBlock Text="{Binding L_Min, StringFormat=Min: {0:F2}}" Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,3"/>
                    <Slider Minimum="0" Maximum="0.99" Value="{Binding L_Min, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding L_Max, StringFormat=Max: {0:F2}}" Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,3"/>
                    <Slider Minimum="0" Maximum="0.99" Value="{Binding L_Max, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="4,0,0,6">
                <StackPanel>
                    <TextBlock Text="Rotate (R0)" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Margin="0,0,8,0"
                                Minimum="{Binding RotateSpeedMin}"
                                Maximum="{Binding RotateSpeedMax}"
                                Value="{Binding R_Speed, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Text="{Binding R_Speed, StringFormat={}{0:F3} /s}"/>
                    </Grid>
                    <TextBlock Text="{Binding R_Min, StringFormat=Min: {0:F2}}" Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,3"/>
                    <Slider Minimum="0" Maximum="0.99" Value="{Binding R_Min, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding R_Max, StringFormat=Max: {0:F2}}" Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,3"/>
                    <Slider Minimum="0" Maximum="0.99" Value="{Binding R_Max, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Background="#33EF4444"
                BorderBrush="{StaticResource Brush.Danger}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10"
                Margin="0,0,0,8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ErrorText}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ErrorText}" Foreground="#FFD2D2" TextWrapping="Wrap"/>
        </Border>

        <ProgressBar Grid.Row="4"
                     Height="4"
                     Margin="0,44,0,0"
                     IsIndeterminate="True"
                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</Window>
