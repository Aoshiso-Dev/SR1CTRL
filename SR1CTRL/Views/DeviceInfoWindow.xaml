<Window x:Class="SR1CTRL.Views.DeviceInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Device Info"
        Width="560"
        Height="500"
        MinWidth="520"
        MinHeight="420"
        Background="{StaticResource Brush.Background}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Device Info" FontSize="18" FontWeight="Bold"/>
            <TextBlock DockPanel.Dock="Right"
                       Foreground="{StaticResource Brush.TextMuted}"
                       Text="{Binding StatusText}"/>
        </DockPanel>

        <Border Grid.Row="1"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14">
            <StackPanel>
                <TextBlock Text="Device (D0)" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding D0Text}"
                         IsReadOnly="True"
                         Height="Auto"
                         MinHeight="36"
                         Margin="0,0,0,8"/>

                <TextBlock Text="TCode Version (D1)" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding D1Text}"
                         IsReadOnly="True"
                         Height="Auto"
                         MinHeight="36"
                         Margin="0,0,0,8"/>

                <TextBlock Text="Axes (D2)" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding D2Text}"
                         IsReadOnly="True"
                         Height="Auto"
                         MinHeight="250"
                         FontFamily="Cascadia Mono"
                         FontSize="12"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
