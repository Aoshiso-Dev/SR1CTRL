<Window x:Class="SR1CTRL.Views.HotkeySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hotkey Settings"
        Width="680"
        Height="420"
        MinWidth="620"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.Background}">
    <Window.Resources>
        <Style x:Key="HotkeyInputBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Foreground" Value="#F3F7FF"/>
            <Setter Property="TextElement.Foreground" Value="#F3F7FF"/>
            <Setter Property="Background" Value="#1B2333"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource Brush.Accent}"/>
            <Setter Property="SelectionBrush" Value="#66A8D8FF"/>
            <Setter Property="SelectionTextBrush" Value="#FFFFFF"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="#223048"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#66E3FF"/>
                </Trigger>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Foreground" Value="#F3F7FF"/>
                    <Setter Property="TextElement.Foreground" Value="#F3F7FF"/>
                    <Setter Property="Background" Value="#1B2333"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="10"
                CornerRadius="8"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                Background="{StaticResource Brush.Surface}">
            <StackPanel>
                <TextBlock Text="機能ごとのホットキー設定" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock Text="割り当てたい機能の入力ボックスをクリックし、ノブを回す/押すと設定されます。"
                           Foreground="{StaticResource Brush.TextMuted}"
                           Margin="0,4,0,0"/>
                <TextBlock Text="{Binding HotkeyCaptureStatus}"
                           Foreground="{StaticResource Brush.Accent}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,10,0,0"
                Padding="12"
                CornerRadius="8"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                Background="{StaticResource Brush.Surface}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="再生/停止"/>
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Style="{StaticResource HotkeyInputBoxStyle}"
                         Margin="8,0,0,6"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="False"
                         Cursor="Hand"
                         HorizontalContentAlignment="Left"
                         FontWeight="SemiBold"
                         Tag="StartStop"
                         Text="{Binding StartStopHotkeyText, Mode=OneWay}"
                         GotKeyboardFocus="HotkeyInputBox_GotKeyboardFocus"/>

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Linear スピードDown"/>
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Style="{StaticResource HotkeyInputBoxStyle}"
                         Margin="8,0,0,6"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="False"
                         Cursor="Hand"
                         HorizontalContentAlignment="Left"
                         FontWeight="SemiBold"
                         Tag="LinearSpeedDown"
                         Text="{Binding LinearSpeedDownHotkeyText, Mode=OneWay}"
                         GotKeyboardFocus="HotkeyInputBox_GotKeyboardFocus"/>

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Linear スピードUp"/>
                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Style="{StaticResource HotkeyInputBoxStyle}"
                         Margin="8,0,0,6"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="False"
                         Cursor="Hand"
                         HorizontalContentAlignment="Left"
                         FontWeight="SemiBold"
                         Tag="LinearSpeedUp"
                         Text="{Binding LinearSpeedUpHotkeyText, Mode=OneWay}"
                         GotKeyboardFocus="HotkeyInputBox_GotKeyboardFocus"/>

                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Rotate スピードDown"/>
                <TextBox Grid.Row="3"
                         Grid.Column="1"
                         Style="{StaticResource HotkeyInputBoxStyle}"
                         Margin="8,0,0,6"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="False"
                         Cursor="Hand"
                         HorizontalContentAlignment="Left"
                         FontWeight="SemiBold"
                         Tag="RotateSpeedDown"
                         Text="{Binding RotateSpeedDownHotkeyText, Mode=OneWay}"
                         GotKeyboardFocus="HotkeyInputBox_GotKeyboardFocus"/>

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Rotate スピードUp"/>
                <TextBox Grid.Row="4"
                         Grid.Column="1"
                         Style="{StaticResource HotkeyInputBoxStyle}"
                         Margin="8,0,0,0"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="False"
                         Cursor="Hand"
                         HorizontalContentAlignment="Left"
                         FontWeight="SemiBold"
                         Tag="RotateSpeedUp"
                         Text="{Binding RotateSpeedUpHotkeyText, Mode=OneWay}"
                         GotKeyboardFocus="HotkeyInputBox_GotKeyboardFocus"/>
            </Grid>
        </Border>
    </Grid>
</Window>
